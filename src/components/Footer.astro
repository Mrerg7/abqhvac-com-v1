---
interface Props {
  disclaimer: string;
  email: string;
  price: string;
  footerLinks: { label: string; href: string }[];
}

const { disclaimer, email, price, footerLinks } = Astro.props;
const mailtoHref = `mailto:${email}?subject=Inquiry%20for%20abqhvac.com%20acquisition`;
---

<footer class="border-t border-white/10 bg-slate-950">
  <!-- Domain Acquisition CTA Strip -->
  <div class="border-b border-white/5 bg-gradient-to-r from-orange-950/30 via-slate-950 to-orange-950/30">
    <div class="max-w-screen-xl mx-auto px-6 py-12">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
        <div class="flex-1 text-center lg:text-left">
          <p class="text-xs font-bold tracking-[2px] text-orange-400 uppercase mb-3">Domain Available for Acquisition</p>
          <h3 class="text-2xl md:text-3xl font-display font-bold tracking-tight mb-2">
            Own <span class="text-orange-400">abqhvac.com</span> — the premier Albuquerque HVAC digital asset
          </h3>
          <p class="text-slate-400 text-sm max-w-xl">
            This premium local domain is available for serious buyers. Secure the most authoritative HVAC domain
            in the Albuquerque metro area and dominate ABQ search results from day one.
          </p>
        </div>
        <div class="flex flex-col items-center lg:items-end gap-3">
          <div class="text-3xl font-display font-bold tracking-tight text-white">{price}</div>
          <div class="text-xs text-slate-400">USD &bull; One-time acquisition</div>
          <a href={mailtoHref}
             class="inline-flex items-center gap-x-2 px-8 py-3 rounded-2xl bg-orange-600 hover:bg-orange-500 text-white font-semibold text-sm transition-all active:scale-[0.985] shadow-lg shadow-orange-600/20">
            <i class="fa-solid fa-envelope"></i>
            <span>{email}</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Disclaimer -->
  <div class="max-w-screen-xl mx-auto px-6 py-6">
    <div class="bg-slate-900/50 border border-white/5 rounded-2xl p-6 mb-6">
      <div class="flex items-start gap-x-3">
        <i class="fa-solid fa-circle-info text-orange-400 mt-0.5 flex-shrink-0"></i>
        <p class="text-xs text-slate-500 leading-relaxed">{disclaimer}</p>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-y-3 text-center md:text-left">
      <div class="text-xs text-slate-500">
        &copy; 2026 abqhvac.com — Premium domain asset. All rights reserved by current owner.
      </div>
      <div class="flex items-center justify-center gap-x-5 text-xs text-slate-500">
        {footerLinks.map((link, i) => (
          <>
            {i > 0 && <span class="text-white/20">&bull;</span>}
            <a href={link.href} class="hover:text-slate-400 transition-colors"
               target={link.href.startsWith('http') ? '_blank' : undefined}
               rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
              {link.label}
            </a>
          </>
        ))}
      </div>
    </div>
  </div>
</footer>
