---
interface Detail {
  label: string;
  value: string;
}

interface Props {
  details: Detail[];
}

const { details } = Astro.props;
---

<section class="max-w-screen-xl mx-auto px-6 py-12 border-t border-slate-800">
  <div class="glass-card p-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8">
      {details.map((d) => (
        <div>
          <div class="text-sm text-slate-400 mb-1">{d.label}</div>
          <div class="text-2xl font-semibold">{d.value}</div>
        </div>
      ))}
    </div>
  </div>
</section>
