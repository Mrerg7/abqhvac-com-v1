---
interface ValueCard {
  icon: string;
  title: string;
  body: string;
}

interface Props {
  headline: string;
  subheadline: string;
  cards: ValueCard[];
}

const { headline, subheadline, cards } = Astro.props;
---

<section id="why" class="max-w-screen-xl mx-auto px-6 py-16 border-t border-slate-800">
  <div class="max-w-2xl mb-12">
    <h2 class="section-title mb-4">{headline}</h2>
    <p class="text-lg text-slate-400">{subheadline}</p>
  </div>

  <div class="grid md:grid-cols-3 gap-6">
    {cards.map((card) => (
      <div class="glass-card p-8">
        <div class="text-orange-400 mb-4">
          <i class={`fa-solid fa-${card.icon} text-3xl`}></i>
        </div>
        <h3 class="font-semibold text-xl mb-3">{card.title}</h3>
        <p class="text-slate-400 leading-relaxed">{card.body}</p>
      </div>
    ))}
  </div>
</section>
